X_CLIENT_ID=your_x_client_id_here

# Optional for confidential clients:
# X_CLIENT_SECRET=your_x_client_secret_here

# Optional override (must match your X app callback URL):
# X_REDIRECT_URI=http://127.0.0.1:8787/callback

# Optional override:
# X_OAUTH_SCOPES=tweet.read users.read tweet.write like.write like.read bookmark.write bookmark.read offline.access

# Optional override:
# X_TOKEN_STORE_PATH=/absolute/path/to/oauth-token.json

# Optional image mode:
# X_IMAGE_MODE=auto # auto | kitty | off
